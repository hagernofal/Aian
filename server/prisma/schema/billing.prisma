model Subscription {
  id                     String             @id @default(uuid())
  organizationId         String             @unique @map("organization_id")
  billingCycle           BillingCycle       @map("billing_cycle")
  status                 SubscriptionStatus
  paymentProvider        String             @map("payment_provider") @db.VarChar(50)
  providerCustomerId     String?            @map("provider_customer_id") @db.VarChar(255)
  providerSubscriptionId String?            @unique @map("provider_subscription_id") @db.VarChar(255)
  currentPeriodStart     DateTime?          @map("current_period_start") @db.Timestamptz
  currentPeriodEnd       DateTime?          @map("current_period_end") @db.Timestamptz
  cancelAtPeriodEnd      Boolean            @default(false) @map("cancel_at_period_end")
  createdAt              DateTime           @default(now()) @map("created_at") @db.Timestamptz
  updatedAt              DateTime           @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id])
  payments     Payment[]

  @@map("subscriptions")
}

model Payment {
  id                String        @id @default(uuid())
  organizationId    String        @map("organization_id")
  subscriptionId    String        @map("subscription_id")
  paymentProvider   String        @map("payment_provider") @db.VarChar(50)
  providerPaymentId String        @unique @map("provider_payment_id") @db.VarChar(255)
  amountCents       Int           @map("amount_cents")
  currency          String        @db.VarChar(10)
  billingCycle      BillingCycle  @map("billing_cycle")
  status            PaymentStatus
  paidAt            DateTime?     @map("paid_at") @db.Timestamptz
  failureReason     String?       @map("failure_reason") @db.Text
  providerPayload   Json?         @map("provider_payload")
  createdAt         DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id])
  subscription Subscription @relation(fields: [subscriptionId], references: [id])

  @@map("payments")
}
