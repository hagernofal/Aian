model OrganizationKnowledgeFile {
  id               String              @id @default(uuid())
  organizationId   String              @map("organization_id")
  uploadedByUserId String?             @map("uploaded_by_user_id")
  originalFileName String              @map("original_file_name") @db.VarChar(255)
  storageKey       String              @unique @map("storage_key") @db.Text
  mimeType         String              @map("mime_type") @db.VarChar(100)
  fileSizeBytes    BigInt              @map("file_size_bytes")
  status           KnowledgeFileStatus @default(pending)
  processingError  String?             @map("processing_error") @db.Text
  uploadedAt       DateTime            @map("uploaded_at") @db.Timestamptz
  processedAt      DateTime?           @map("processed_at") @db.Timestamptz
  createdAt        DateTime            @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime            @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  organization   Organization @relation(fields: [organizationId], references: [id])
  uploadedByUser User?        @relation(fields: [uploadedByUserId], references: [id])

  @@map("organization_knowledge_files")
}

model OnboardingProgress {
  id             String    @id @default(uuid())
  organizationId String    @unique @map("organization_id")
  currentStep    String    @map("current_step") @db.VarChar(100)
  completedSteps Json      @map("completed_steps")
  isCompleted    Boolean   @default(false) @map("is_completed")
  startedAt      DateTime  @map("started_at") @db.Timestamptz
  completedAt    DateTime? @map("completed_at") @db.Timestamptz
  updatedAt      DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id])

  @@map("onboarding_progress")
}

model EyeSyncJob {
  id                 String          @id @default(uuid())
  organizationEyeId  String          @map("organization_eye_id")
  integrationId      String?         @map("integration_id")
  triggerType        SyncTriggerType @map("trigger_type")
  status             SyncJobStatus   @default(queued)
  startedAt          DateTime?       @map("started_at") @db.Timestamptz
  finishedAt         DateTime?       @map("finished_at") @db.Timestamptz
  progressPercentage Int             @map("progress_percentage") @db.SmallInt
  summary            Json
  errorMessage       String?         @map("error_message") @db.Text
  createdAt          DateTime        @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  organizationEye OrganizationEye @relation(fields: [organizationEyeId], references: [id])
  integration     Integration?    @relation(fields: [integrationId], references: [id])

  @@map("eye_sync_jobs")
}
