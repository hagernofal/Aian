{
  "info": {
    "name": "Aian - Slack Integration",
    "description": "Postman collection to test the full Slack OAuth flow and provider client endpoints.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Slack Install (Redirect)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/integrations/slack/install?organizationEyeId={{organizationEyeId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "integrations",
            "slack",
            "install"
          ],
          "query": [
            {
              "key": "organizationEyeId",
              "value": "{{organizationEyeId}}",
              "description": "The ID of the OrganizationEye from the DB"
            }
          ]
        },
        "description": "Note: This endpoint is normally opened in a browser because it redirects the user to the Slack OAuth consent screen. It won't return JSON."
      },
      "response": []
    },
    {
      "name": "2. Slack Callback (Token Exchange)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var jsonData = pm.response.json();",
              "",
              "if (jsonData.success && jsonData.data && jsonData.data.connectionId) {",
              "    pm.collectionVariables.set(\"connectionId\", jsonData.data.connectionId);",
              "    console.log(\"Saved connectionId: \" + jsonData.data.connectionId);",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/integrations/slack/callback?code=REPLACE_WITH_CODE&state={{organizationEyeId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "integrations",
            "slack",
            "callback"
          ],
          "query": [
            {
              "key": "code",
              "value": "REPLACE_WITH_CODE",
              "description": "The OAuth code returned by Slack in the redirect URL"
            },
            {
              "key": "state",
              "value": "{{organizationEyeId}}",
              "description": "The state parameter containing the eye ID"
            }
          ]
        },
        "description": "Simulates the redirect from Slack. Paste the `code` you get from the browser URL. On success, the script automatically saves the `connectionId` to the collection variables for the next requests!"
      },
      "response": []
    },
    {
      "name": "3. Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/eyes/:connectionId/health",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "eyes",
            ":connectionId",
            "health"
          ],
          "variable": [
            {
              "key": "connectionId",
              "value": "{{connectionId}}",
              "description": "Automatically populated by the Callback request"
            }
          ]
        }
      },
      "response": []
    },
    {
      "name": "4. Fetch Available Channels",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/eyes/:connectionId/resources/available",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "eyes",
            ":connectionId",
            "resources",
            "available"
          ],
          "variable": [
            {
              "key": "connectionId",
              "value": "{{connectionId}}",
              "description": "Automatically populated by the Callback request"
            }
          ]
        }
      },
      "response": []
    },
    {
      "name": "5. Disconnect (Revoke)",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/eyes/:connectionId",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "eyes",
            ":connectionId"
          ],
          "variable": [
            {
              "key": "connectionId",
              "value": "{{connectionId}}",
              "description": "Automatically populated by the Callback request"
            }
          ]
        },
        "description": "Revokes the token on Slack's end, deletes the connection from the database, and sets the OrganizationEye status back to disconnected."
      },
      "response": []
    },
    {
      "name": "6. Send Message",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"targetId\": \"{{slackChannelId}}\",\n  \"text\": \"🚀 *Hello from Aian!*\\n\\nI am *Aian*, your new intelligent assistant, successfully connected to your Slack workspace!\\n\\nI'm here to help streamline your team's workflow, organize knowledge, and keep everything running smoothly.\\n\\n*What can I do?*\\n• 🔍 *Analyze* context from discussions and threads.\\n• 🧠 *Synthesize* knowledge into actionable insights.\\n• ⚡ *Automate* tedious parts of your day.\\n\\nIf you have any questions or just want to say hi, feel free to tag me. Let's build something amazing together!\\n\\n_Beep boop. Connection test successful. ✅_\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/eyes/:connectionId/messages",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "eyes",
            ":connectionId",
            "messages"
          ],
          "variable": [
            {
              "key": "connectionId",
              "value": "{{connectionId}}",
              "description": "Automatically populated by the Callback request"
            }
          ]
        },
        "description": "Sends a message to a Slack channel via the MessagesService. Set `targetId` to any channel ID (e.g. C12345) your bot has access to. Optionally add `blocks`, `threadId`, or `broadcastReply`."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var jsonData = pm.response.json();",
              "if (jsonData.success && jsonData.data && jsonData.data.messageId) {",
              "    pm.collectionVariables.set('lastMessageTs', jsonData.data.messageId);",
              "    console.log('Saved lastMessageTs: ' + jsonData.data.messageId);",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "response": []
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:12345",
      "type": "string"
    },
    {
      "key": "organizationEyeId",
      "value": "d155bd83-8327-4414-b5c9-041f1efb86fd",
      "type": "string"
    },
    {
      "key": "connectionId",
      "value": "",
      "type": "string"
    },
    {
      "key": "slackChannelId",
      "value": "REPLACE_WITH_CHANNEL_ID",
      "type": "string"
    },
    {
      "key": "lastMessageTs",
      "value": "",
      "type": "string"
    }
  ]
}