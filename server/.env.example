# ============================================================
# Server
# ============================================================
NODE_ENV=development
PORT=1234

# ============================================================
# PostgreSQL (Docker Compose)
# ============================================================
POSTGRES_USER=aian_user
POSTGRES_PASSWORD=aian_password
POSTGRES_DB=aian_db
POSTGRES_PORT=5433

# Prisma connection string (built from the vars above)
DATABASE_URL="postgresql://aian_user:aian_password@localhost:5433/aian_db?schema=public"

# ============================================================
# Email & Frontend Configuration
# ============================================================
FRONTEND_URL=http://localhost:3000

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM="Aian <your_email@gmail.com>"


JWT_SECRET=
JWT_SECRET_REFRESH_TOKEN=


# ==============================================================
# Paymob Payment Gateway
# ==============================================================
PAYMOB_SECRET_KEY=
PAYMOB_PUBLIC_KEY=
PAYMOB_PAYMENT_METHODS=
PAYMOB_HMAC_SECRET=
APP_URL=http://localhost:3000
PAYMOB_BASE_URL=https://accept.paymob.com/api
PAYMOB_WEBHOOK_SECRET=


# ==============================================================
# OAUTH
# ==============================================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ============================================================
# Encryption (AES-256-GCM for OAuth token storage)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ============================================================
ENCRYPTION_KEY=your_64_char_hex_string_here

# ============================================================
# Slack Integration
# Found at: https://api.slack.com/apps → Your App → Basic Information
# ============================================================
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=

# GitHub App Integration
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_WEBHOOK_SECRET=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
GITHUB_APP_NAME=