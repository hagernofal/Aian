# ============================================================
# Server
# ============================================================
NODE_ENV=development
PORT=1234

# ============================================================
# PostgreSQL (Docker Compose)
# ============================================================
POSTGRES_USER=aian_user
POSTGRES_PASSWORD=aian_password
POSTGRES_DB=aian_db
POSTGRES_PORT=5433

# Prisma connection string (built from the vars above)
DATABASE_URL="postgresql://aian_user:aian_password@localhost:5433/aian_db?schema=public"

# ============================================================
# Email & Frontend Configuration
# ============================================================
FRONTEND_URL=http://localhost:3000

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM="Aian <your_email@gmail.com>"


JWT_SECRET=
JWT_SECRET_REFRESH_TOKEN=


# ==============================================================
# OAUTH
# ==============================================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=